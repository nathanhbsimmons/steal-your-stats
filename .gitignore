# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
# pnpm 10+ auto-regenerates this locally for build-script approval; deploy
# runs pnpm 9 which can't parse it (see package.json pnpm.onlyBuiltDependencies)
/pnpm-workspace.yaml
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# disk cache — commit gd-setlists.json and archive-index.json so deploys start warm; ignore everything else
/.cache/*
!/.cache/gd-setlists.json
!/.cache/archive-index.json

# claude code local settings (machine-specific, e.g. enabled MCP servers)
.claude/settings.local.json
